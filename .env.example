# Docker Compose dependencies
T_UNI_DOCKER_MYSQL_ROOT_PASSWORD=123456
T_UNI_DOCKER_MYSQL_PORT=3306
T_UNI_DOCKER_REDIS_PORT=6379
T_UNI_DOCKER_MINIO_PORT=9000
T_UNI_DOCKER_MINIO_CONSOLE_PORT=9001

# Server runtime
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=10457
T_UNI_DB_HOST=host.docker.internal
T_UNI_DB_PORT=3306
T_UNI_DB_NAME=tuni
T_UNI_DB_USERNAME=root
T_UNI_DB_PASSWORD=123456
T_UNI_REDIS_HOST=host.docker.internal
T_UNI_REDIS_PORT=6379
T_UNI_REDIS_DATABASE=0
T_UNI_REDIS_NAMESPACE=tuni-local
T_UNI_REDIS_PASSWORD=
T_UNI_JWT_SECRET=replace_with_a_secret_at_least_32_bytes_long
WX_MINIAPP_APPID=replace_with_your_appid
WX_MINIAPP_SECRET=replace_with_your_secret
WX_AUTH_LOGIN_IDENTIFIER=MA_OPEN_ID

# Admin runtime (optional)
T_UNI_ADMIN_SERVER_PORT=7840
T_UNI_ADMIN_DB_HOST=host.docker.internal
T_UNI_ADMIN_DB_PORT=3306
T_UNI_ADMIN_DB_NAME=tuni_admin
T_UNI_ADMIN_DB_USERNAME=root
T_UNI_ADMIN_DB_PASSWORD=123456
T_UNI_ADMIN_REDIS_HOST=host.docker.internal
T_UNI_ADMIN_REDIS_PORT=6379
T_UNI_ADMIN_REDIS_DATABASE=0
T_UNI_ADMIN_REDIS_NAMESPACE=tuni-local
T_UNI_ADMIN_REDIS_PASSWORD=
T_UNI_ADMIN_JWT_SECRET=replace_with_a_secret_at_least_32_bytes_long
T_UNI_ADMIN_FILE_STORAGE_PLATFORM=local-plus-1
T_UNI_ADMIN_LOCAL_STORAGE_PATH=/app/data/t-uni-admin/
T_UNI_ADMIN_MINIO_ENABLED=true
T_UNI_ADMIN_MINIO_ENDPOINT=http://localhost:9000
T_UNI_ADMIN_MINIO_DOMAIN=http://localhost:9000/tuni-admin
T_UNI_ADMIN_MINIO_ACCESS_KEY=tuniadmin
T_UNI_ADMIN_MINIO_SECRET_KEY=tuniadmin123456
T_UNI_ADMIN_MINIO_BUCKET=tuni-admin
T_UNI_ADMIN_MINIO_AUTO_CREATE_BUCKET=true
T_UNI_ADMIN_MINIO_PUBLIC_READ=true

# Qiniu (optional)
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=
QINIU_CDN_TIMESTAMP_KEY=

# OpenIM (optional)
OPENIM_ENABLED=false
OPENIM_API_ADDRESS=http://localhost:10002
OPENIM_WS_ADDRESS=ws://localhost:10001
OPENIM_ADMIN_USER_ID=imAdmin
OPENIM_ADMIN_SECRET=
OPENIM_USER_ID_PREFIX=tuni_
OPENIM_SYSTEM_NOTICE_USER_ID=tuni_system
OPENIM_SYSTEM_NOTICE_NICKNAME=系统通知
OPENIM_SYSTEM_NOTICE_AVATAR=
OPENIM_DEFAULT_USER_AVATAR=
OPENIM_WEBHOOK_TOKEN=replace_with_token

# WeChat Pay (optional)
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_MCH_SERIAL_NO=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_NOTIFY_BASE_URL=
WECHAT_PAY_PAY_NOTIFY_PATH=/payment/notify/wechat/pay
WECHAT_PAY_REFUND_NOTIFY_PATH=/payment/notify/wechat/refund
WECHAT_PAY_ORDER_EXPIRE_MINUTES=15
