# 自动处理行尾符
* text=auto eol=lf

# 源代码文件统一使用 UTF-8 与 LF
*.java text eol=lf encoding=utf-8
*.xml text eol=lf encoding=utf-8
*.yml text eol=lf encoding=utf-8
*.yaml text eol=lf encoding=utf-8
*.properties text eol=lf encoding=utf-8
*.sql text eol=lf encoding=utf-8
*.md text eol=lf encoding=utf-8
*.txt text eol=lf encoding=utf-8
*.json text eol=lf encoding=utf-8
*.log text eol=lf encoding=utf-8
*.conf text eol=lf encoding=utf-8

# 前端文件
*.vue text eol=lf encoding=utf-8
*.js text eol=lf encoding=utf-8
*.mjs text eol=lf encoding=utf-8
*.cjs text eol=lf encoding=utf-8
*.ts text eol=lf encoding=utf-8
*.jsx text eol=lf encoding=utf-8
*.tsx text eol=lf encoding=utf-8
*.html text eol=lf encoding=utf-8
*.htm text eol=lf encoding=utf-8
*.css text eol=lf encoding=utf-8
*.scss text eol=lf encoding=utf-8
*.less text eol=lf encoding=utf-8
*.wxml text eol=lf encoding=utf-8
*.wxss text eol=lf encoding=utf-8

# 确保 shell 脚本使用 LF
*.sh text eol=lf

# 确保 Windows 批处理使用 CRLF
*.bat text eol=crlf
